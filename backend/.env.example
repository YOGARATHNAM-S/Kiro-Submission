# ═══════════════════════════════════════════════════════════
# AI Touch-to-Explain Learning Assistant — Environment Config
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials.

# ── Mode ──
# Set to "aws" to use real AWS services, "mock" to use mock services
MODE=aws

# ── AWS Credentials ──
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# ── LLM Provider ──
# Options: "bedrock", "openai", "mock"
LLM_PROVIDER=bedrock

# AWS Bedrock (Claude)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# Alternative models:
#   anthropic.claude-3-sonnet-20240229-v1:0
#   anthropic.claude-3-5-sonnet-20241022-v2:0
#   meta.llama3-8b-instruct-v1:0

# OpenAI (GPT-4)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# Alternative models: gpt-4o, gpt-4-turbo, gpt-3.5-turbo

# ── AWS Polly (Text-to-Speech) ──
# Set to "true" to use real AWS Polly, "false" for mock
USE_POLLY=true
POLLY_VOICE_ID=Joanna
# Neural voices: Joanna, Matthew, Amy, Brian, Ivy, Kendra

# ── AWS Textract (OCR) ──
# Set to "true" to use real AWS Textract, "false" for mock
USE_TEXTRACT=true

# ── AWS DynamoDB ──
# Set to "true" to use real DynamoDB, "false" for in-memory
USE_DYNAMODB=true
DYNAMODB_HIGHLIGHTS_TABLE=ai-learning-highlights
DYNAMODB_FLASHCARDS_TABLE=ai-learning-flashcards
DYNAMODB_DOCUMENTS_TABLE=ai-learning-documents

# ── Server ──
PORT=3001
